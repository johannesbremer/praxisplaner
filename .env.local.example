# Posthog configuration
VITE_PUBLIC_POSTHOG_KEY=your_posthog_key_here
VITE_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com

# This is a shared default backend you can't modify the code for.
# In order to create your own backend, run `npx convex dev`.
CONVEX_DEPLOYMENT=your_convex_deployment_here
VITE_CONVEX_URL=your_convex_url_here
VITE_CONVEX_SITE_URL=your_convex_site_url_here
CONVEX_URL=your_convex_url_here

# Codex worktree setup reads these ignored local values to select the shared
# preview backend without tracking deployment-specific URLs in git.
CONVEX_IMPORT_DEPLOYMENT=your_convex_deployment_name_here
CONVEX_SELECTED_DEPLOYMENT=preview:your_convex_deployment_name_here
CONVEX_CLOUD_URL=https://your_convex_deployment_name_here.eu-west-1.convex.cloud
CONVEX_SITE_URL=https://your_convex_deployment_name_here.eu-west-1.convex.site

# TelefonKI worker configuration
OPENAI_API_KEY=your_openai_api_key_here
TELEFONKI_PRACTICE_SECRETS={"+495421000000":"your_practice_scoped_telefonki_secret_here"}
TELEFONKI_REALTIME_MODEL=gpt-realtime-1.5
TELEFONKI_REALTIME_VOICE=echo

# WorkOS AuthKit configuration
# Get these from https://dashboard.workos.com/
VITE_WORKOS_CLIENT_ID=your_workos_client_id_here

# Optional local/preview-only agent bypass for route gates.
# This is ignored unless Vite is running in dev mode or VITE_VERCEL_ENV=preview.
VITE_AUTH_BYPASS_ENABLED=false
VITE_VERCEL_ENV=development
