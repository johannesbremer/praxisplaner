# .env.local.example is documentation only.
# Copy selected keys into your private .env.local when you need local overrides.

# Optional PostHog configuration
VITE_PUBLIC_POSTHOG_KEY=your_posthog_key_here
VITE_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com

# Optional Convex bootstrap inputs for Codex worktree setup.
# Provide either a team/project pair for creating a per-worktree preview backend:
CONVEX_TEAM_SLUG=your_convex_team_slug_here
CONVEX_PROJECT_SLUG=your_convex_project_slug_here

# Or provide an existing preview/dev source deployment:
CONVEX_DEPLOYMENT=preview:your_preview_deployment_here

# Generated by setup after selecting the preview backend.
# Do not hand-maintain these unless you are intentionally overriding setup.
VITE_CONVEX_URL=your_generated_convex_cloud_url_here
VITE_CONVEX_SITE_URL=your_generated_convex_site_url_here
CONVEX_URL=your_generated_convex_cloud_url_here

# TelefonKI worker configuration
OPENAI_API_KEY=your_openai_api_key_here
TELEFONKI_PRACTICE_SECRETS={"+495421000000":"your_practice_scoped_telefonki_secret_here"}
TELEFONKI_REALTIME_MODEL=gpt-realtime-1.5
TELEFONKI_REALTIME_VOICE=echo

# WorkOS AuthKit configuration
# Get these from https://dashboard.workos.com/
VITE_WORKOS_CLIENT_ID=your_workos_client_id_here

# Optional local/preview-only agent bypass for route gates.
# This is ignored unless Vite is running in dev mode or VITE_VERCEL_ENV=preview.
VITE_AUTH_BYPASS_ENABLED=false
VITE_VERCEL_ENV=development
