{
  "name": "praxisplaner",
  "version": "0.0.1",
  "private": true,
  "description": "TBD",
  "sideEffects": false,
  "type": "module",
  "scripts": {
    "build": "vite build",
    "build:vercel": "scripts/build-vercel.sh",
    "ci-check": "pnpm --silent ci-check:gen && pnpm --silent lint && pnpm tsc && pnpm exec prettier --write . --log-level silent && pnpm --silent ci-check:test && pnpm --silent ci-check:test:property && pnpm --silent ci-check:build && echo 'ci-check passed: gen, lint, tsc, format, test, property-test, and build completed successfully.'",
    "ci-check:build": "sh -c 'log=\"${TMPDIR:-/tmp}/praxisplaner-build-$$.log\"; pnpm exec vite build --logLevel silent >\"$log\" 2>&1 || { cat \"$log\" >&2; rm -f \"$log\"; exit 1; }; rm -f \"$log\"'",
    "ci-check:gen": "sh -c 'log=\"${TMPDIR:-/tmp}/praxisplaner-gen-$$.log\"; pnpm exec tsr generate >\"$log\" 2>&1 && pnpm exec convex codegen >>\"$log\" 2>&1 || { cat \"$log\" >&2; rm -f \"$log\"; exit 1; }; rm -f \"$log\"'",
    "ci-check:test": "sh -c 'log=\"${TMPDIR:-/tmp}/praxisplaner-test-$$.log\"; VITE_ENABLE_POSTHOG_IN_DEV=true pnpm exec vitest --run >\"$log\" 2>&1 || { cat \"$log\" >&2; rm -f \"$log\"; exit 1; }; rm -f \"$log\"'",
    "ci-check:test:property": "sh -c 'log=\"${TMPDIR:-/tmp}/praxisplaner-property-test-$$.log\"; FAST_CHECK_NUM_RUNS=\"${FAST_CHECK_NUM_RUNS:-100}\" FAST_CHECK_SEED=\"${FAST_CHECK_SEED:-1}\" VITE_ENABLE_POSTHOG_IN_DEV=true pnpm exec vitest --run --config vitest.property.config.ts >\"$log\" 2>&1 || { cat \"$log\" >&2; rm -f \"$log\"; exit 1; }; rm -f \"$log\"'",
    "dev": "pnpm dev:frontend & pnpm dev:backend",
    "dev:backend": "pnpm exec convex dev",
    "dev:frontend": "vite dev",
    "dev:telefonki": "tsx agents/telefonki/agent.ts dev",
    "format": "prettier --write .",
    "format:list": "prettier --list-different .",
    "gen": "pnpm gen:routes & pnpm gen:convex",
    "gen:convex": "pnpm exec convex codegen",
    "gen:routes": "pnpm exec tsr generate",
    "lint": "eslint . --fix",
    "lint:check": "eslint . --max-warnings 0",
    "migration:build-patients": "node scripts/migration/build-pvs-patients-from-appointments.mts",
    "migration:convert-praxistimer": "node scripts/migration/convert-praxistimer-export.mts",
    "migration:correlate-legacy": "node scripts/migration/correlate-legacy-appointments.mts",
    "migration:import-local-identities": "node scripts/migration/import-booking-identity-associations-local.mts",
    "migration:replay-legacy-booking": "node scripts/migration/build-legacy-booking-step-replay.mts",
    "migration:report-name-changes": "node scripts/migration/report-pvs-patient-name-changes.mts",
    "seed:preview": "mkdir -p .cache/seed && rm -f .cache/seed/preview.zip && cd seed_data_preview && zip -qr ../.cache/seed/preview.zip .",
    "start": "vite start",
    "start:telefonki": "tsx agents/telefonki/agent.ts start",
    "test": "VITE_ENABLE_POSTHOG_IN_DEV=true vitest --run",
    "test:property": "sh -c 'FAST_CHECK_NUM_RUNS=\"${FAST_CHECK_NUM_RUNS:-100}\" VITE_ENABLE_POSTHOG_IN_DEV=true pnpm exec vitest --run --config vitest.property.config.ts'",
    "test:property:overnight": "VITE_ENABLE_POSTHOG_IN_DEV=true node scripts/run-property-overnight.mjs"
  },
  "dependencies": {
    "@convex-dev/react-query": "0.1.0",
