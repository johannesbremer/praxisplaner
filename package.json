    "ical-generator": "^11.0.0",
    "idb-keyval": "^6.2.5",
    "livekit-client": "^2.19.1",
    "livekit-server-sdk": "^2.15.4",
    "lucide-react": "^1.17.0",
    "neverthrow": "^8.2.0",
    "next-themes": "^0.4.6",
    "posthog-js": "^1.379.2",
    "radix-ui": "latest",
    "react": "^19.2.7",
    "react-day-picker": "10.0.1",
    "react-dom": "^19.2.7",
    "react-hot-toast": "^2.6.0",
    "react-phone-number-input": "^3.4.17",
    "react-scan": "^0.5.7",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "temporal-polyfill": "^0.3.2",
